@inherits LayoutComponentBase
@inject Loc L

<div class="zk-app">
    <NavMenu />

    <main class="zk-main">
        <div class="zk-container">
            @Body
        </div>
    </main>

    <footer class="zk-footer zk-dark">
        <div class="zk-container">
            <div class="zk-footer-grid">
                <div>
                    <BrandLogo Href="" Size="40" OnDark="true" />
                    <p class="zk-footer-tag">@L["footer.tagline"]</p>
                </div>
                <div>
                    <h4>@L["footer.explore"]</h4>
                    <ul>
                        <li><a href="">@L["nav.home"]</a></li>
                        <li><a href="listings">@L["nav.listings"]</a></li>
                        <li><a href="bookings">@L["nav.bookings"]</a></li>
                        <li><a href="wallet">@L["nav.wallet"]</a></li>
                    </ul>
                </div>
                <div>
                    <h4>@L["footer.account"]</h4>
                    <ul>
                        <li><a href="login">@L["nav.login"]</a></li>
                        <li><a href="register">@L["nav.register"]</a></li>
                    </ul>
                </div>
            </div>
            <div class="zk-footer-copy">@L["footer.copyright"]</div>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Beklenmeyen bir hata oluştu.
    <a href="." class="reload">Yeniden yükle</a>
    <span class="dismiss">🗙</span>
</div>
