@page "/listings"
@using System.Globalization
@implements IDisposable
@inject ApiClient Api
@inject AuthState Auth
@inject Loc L

<PageTitle>@L["listings.title"] — Zaman Takası</PageTitle>

<div class="zk-page-head">
    <div>
        <h1>@L["listings.title"]</h1>
        <p>@L["listings.subtitle"]</p>
    </div>
    @if (Auth.IsAuthenticated)
    {
        <button class="zk-btn zk-btn-ghost" @onclick="ToggleNewForm">
            <i class="ti ti-plus"></i> @L["listings.new"]
        </button>
    }
</div>

@if (msg is not null) { <div class="alert alert-success zk-mt">@msg</div> }
@if (err is not null) { <div class="alert alert-danger zk-mt">@err</div> }

@if (Auth.IsAuthenticated && showNewForm)
{
    <div class="zk-card zk-mt" style="max-width:560px;">
        <h3 style="margin:0 0 14px; font-size:19px;">@L["listings.newHeading"]</h3>
        <input class="form-control mb-2" placeholder="@L["listings.titlePlaceholder"]" @bind="newTitle" />
        <textarea class="form-control mb-2" rows="3" placeholder="@L["listings.descPlaceholder"]" @bind="newDesc"></textarea>
        <select class="form-select mb-3" @bind="newTier">
            @foreach (var t in Enum.GetValues<SkillTier>())
            {
                <option value="@t">@t (×@((int)t))</option>
            }
        </select>
        <div style="display:flex; gap:10px;">
            <button class="zk-btn zk-btn-primary" @onclick="CreateListing"><i class="ti ti-check"></i> @L["common.create"]</button>
            <button class="zk-btn zk-btn-ghost" @onclick="ToggleNewForm">@L["common.cancel"]</button>
        </div>
    </div>
}
else if (!Auth.IsAuthenticated)
{
    <div class="alert alert-secondary zk-mt">
        @L["listings.signInPrompt"] <a href="login">@L["nav.login"]</a>
    </div>
}

@if (loading)
{
    <p class="zk-mt" style="color:var(--zk-muted);">@L["common.loading"]</p>
}
else if (listings.Count == 0)
{
    <div class="zk-card zk-mt" style="text-align:center; padding:40px;">
        <i class="ti ti-clipboard-off" style="font-size:36px; color:var(--zk-muted);"></i>
        <p style="margin:12px 0 0; color:var(--zk-muted);">@L["listings.empty"]</p>
    </div>
}
else
{
    <div class="zk-grid zk-mt">
        @foreach (var l in listings)
        {
            <div class="zk-card hoverable zk-listing-card">
                <div class="zk-listing-head">
                    <div class="zk-avatar @AvatarClass(l.Tier)">@Initial(l.ProviderDisplayName)</div>
                    <div>
                        <div class="zk-listing-name">@l.ProviderDisplayName</div>
                        <div class="zk-listing-meta"><i class="ti ti-star"></i> @l.Tier</div>
                    </div>
                    <span class="zk-badge @BadgeClass(l.Tier)" style="margin-left:auto;">
                        <i class="ti @BadgeIcon(l.Tier)"></i> @l.Tier ×@((int)l.Tier)
                    </span>
                </div>

                <h3 class="zk-listing-title">@l.Title</h3>
                <p class="zk-listing-desc">@l.Description</p>

                <div class="zk-listing-foot">
                    <div style="display:flex; align-items:baseline; gap:4px;">
                        <ZkAmount Amount="l.HourlyCreditRate" Size="lg" />
                        <span style="font-size:12.5px; color:var(--zk-muted);">@L["common.perHour"]</span>
                    </div>

                    @if (Auth.IsAuthenticated && l.ProviderUserId != Auth.UserId)
                    {
                        <div style="display:flex; align-items:center; gap:9px;">
                            <div class="zk-stepper">
                                <button @onclick="() => AdjustHours(l.Id, -0.5m)" aria-label="-">−</button>
                                <span class="zk-stepper-val">@FormatHours(hours[l.Id])@L["common.hourShort"]</span>
                                <button @onclick="() => AdjustHours(l.Id, 0.5m)" aria-label="+">+</button>
                            </div>
                            <button class="zk-btn zk-btn-primary zk-btn-sm" @onclick="() => Book(l)">@L["listings.book"]</button>
                        </div>
                    }
                    else if (Auth.IsAuthenticated && l.ProviderUserId == Auth.UserId)
                    {
                        <span class="zk-badge zk-badge-ink">@L["listings.ownListing"]</span>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ListingDto> listings = new();
    private readonly Dictionary<Guid, decimal> hours = new();
    private bool loading = true;
    private bool showNewForm;
    private string? msg;
    private string? err;

    private string newTitle = "";
    private string newDesc = "";
    private SkillTier newTier = SkillTier.Basic;

    protected override async Task OnInitializedAsync()
    {
        Auth.Changed += OnChanged;
        await Auth.EnsureLoadedAsync();
        await Load();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task Load()
    {
        loading = true;
        try
        {
            listings = await Api.GetListingsAsync() ?? new();
            foreach (var l in listings) hours.TryAdd(l.Id, 1m);
        }
        catch (ApiException ex) { err = ex.Message; }
        finally { loading = false; }
    }

    private void ToggleNewForm() { showNewForm = !showNewForm; msg = err = null; }

    private void AdjustHours(Guid id, decimal delta)
    {
        var v = hours.TryGetValue(id, out var cur) ? cur : 1m;
        hours[id] = Math.Max(0.5m, v + delta);
    }

    private static string FormatHours(decimal h) => h.ToString("0.##", CultureInfo.CurrentCulture);

    private async Task Book(ListingDto l)
    {
        msg = err = null;
        try
        {
            var b = await Api.CreateBookingAsync(new CreateBookingRequest(l.Id, hours[l.Id]));
            var cost = b!.CreditCost.ToString("0.##", CultureInfo.CurrentCulture);
            msg = L.Fmt("listings.bookingCreated", cost, StatusName(b.Status));
        }
        catch (ApiException ex) { err = ex.Message; }
    }

    private async Task CreateListing()
    {
        msg = err = null;
        try
        {
            await Api.CreateListingAsync(new CreateListingRequest(newTitle, newDesc, newTier));
            newTitle = newDesc = ""; newTier = SkillTier.Basic;
            showNewForm = false;
            await Load();
            msg = L["listings.created"];
        }
        catch (ApiException ex) { err = ex.Message; }
    }

    // ---- görsel yardımcılar ----
    private static string Initial(string? name) => string.IsNullOrWhiteSpace(name) ? "?" : char.ToUpper(name.Trim()[0]).ToString();

    private string StatusName(BookingStatus s) => s switch
    {
        BookingStatus.Pending => L["status.pending"],
        BookingStatus.Accepted => L["status.accepted"],
        BookingStatus.Completed => L["status.completed"],
        BookingStatus.Cancelled => L["status.cancelled"],
        _ => s.ToString()
    };

    private static string BadgeClass(SkillTier t) => t switch
    {
        SkillTier.Verified => "zk-badge-cyan",
        SkillTier.Professional => "zk-badge-purple",
        _ => "zk-badge-ink"
    };

    private static string BadgeIcon(SkillTier t) => t switch
    {
        SkillTier.Professional => "ti-award",
        _ => "ti-rosette-discount-check"
    };

    private static string AvatarClass(SkillTier t) => t switch
    {
        SkillTier.Professional => "zk-badge-purple",
        SkillTier.Verified => "zk-badge-cyan",
        _ => "zk-badge-ink"
    };

    public void Dispose() => Auth.Changed -= OnChanged;
}
