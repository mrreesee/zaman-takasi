@page "/login"
@inject ApiClient Api
@inject AuthState Auth
@inject NavigationManager Nav
@inject Loc L

<PageTitle>@L["auth.login.submit"] — Zaman Takası</PageTitle>

<div class="zk-auth-wrap">
    <div class="zk-auth-card">
        <div class="zk-auth-head">
            <BrandLogo Href="" Size="46" ShowText="false" />
            <h1>@L["auth.login.welcome"]</h1>
            <p>@L["auth.login.sub"]</p>
        </div>

        <div class="zk-field">
            <label>@L["auth.email"]</label>
            <input class="form-control" type="email" @bind="email" @bind:event="oninput" placeholder="@L["auth.emailPlaceholder"]" />
        </div>
        <div class="zk-field">
            <label>@L["auth.password"]</label>
            <input class="form-control" type="password" @bind="password" @bind:event="oninput" @onkeydown="OnKey" placeholder="••••••••" />
        </div>

        <button class="zk-btn zk-btn-primary zk-block" @onclick="Submit" disabled="@busy">
            @if (busy) { <span>@L["auth.login.submitting"]</span> } else { <span><i class="ti ti-login-2"></i> @L["auth.login.submit"]</span> }
        </button>

        @if (error is not null) { <div class="alert alert-danger zk-mt">@error</div> }

        <div class="zk-auth-foot">@L["auth.login.noAccount"] <a href="register">@L["nav.register"]</a></div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool busy;

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }

    private async Task Submit()
    {
        error = null; busy = true;
        try
        {
            var resp = await Api.LoginAsync(new LoginRequest(email, password));
            await Auth.SignInAsync(resp!);
            Nav.NavigateTo("/listings");
        }
        catch (ApiException ex) { error = ex.Message; }
        finally { busy = false; }
    }
}
