@page "/login"
@inject ApiClient Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Giriş — Zaman Takası</PageTitle>

<div class="zk-auth-wrap">
    <div class="zk-auth-card">
        <div class="zk-auth-head">
            <BrandLogo Href="" Size="46" ShowText="false" />
            <h1>Tekrar hoş geldin</h1>
            <p>Hesabına giriş yap ve takasa devam et.</p>
        </div>

        <div class="zk-field">
            <label>E-posta</label>
            <input class="form-control" type="email" @bind="email" @bind:event="oninput" placeholder="ornek@demo.local" />
        </div>
        <div class="zk-field">
            <label>Parola</label>
            <input class="form-control" type="password" @bind="password" @bind:event="oninput" @onkeydown="OnKey" placeholder="••••••••" />
        </div>

        <button class="zk-btn zk-btn-primary zk-block" @onclick="Submit" disabled="@busy">
            @if (busy) { <span>Giriş yapılıyor…</span> } else { <span><i class="ti ti-login-2"></i> Giriş yap</span> }
        </button>

        @if (error is not null) { <div class="alert alert-danger zk-mt">@error</div> }

        <div class="zk-demo-note">
            <i class="ti ti-info-circle"></i> Demo: <b>alice@@demo.local</b> / <b>bob@@demo.local</b> — parola <b>Passw0rd!</b>
        </div>

        <div class="zk-auth-foot">Hesabın yok mu? <a href="register">Kayıt ol</a></div>
    </div>
</div>

@code {
    private string email = "alice@demo.local";
    private string password = "Passw0rd!";
    private string? error;
    private bool busy;

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }

    private async Task Submit()
    {
        error = null; busy = true;
        try
        {
            var resp = await Api.LoginAsync(new LoginRequest(email, password));
            await Auth.SignInAsync(resp!);
            Nav.NavigateTo("/listings");
        }
        catch (ApiException ex) { error = ex.Message; }
        finally { busy = false; }
    }
}
