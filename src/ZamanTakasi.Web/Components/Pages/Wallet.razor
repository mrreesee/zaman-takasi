@page "/wallet"
@using System.Globalization
@inject ApiClient Api
@inject AuthState Auth

<PageTitle>Cüzdan — Zaman Takası</PageTitle>

<div class="zk-page-head">
    <div>
        <h1>Cüzdan</h1>
        <p>Zaman kredilerin ve tüm hareketlerin.</p>
    </div>
</div>

@if (!ready)
{
    <p style="color:var(--zk-muted);">Yükleniyor…</p>
}
else if (!Auth.IsAuthenticated)
{
    <div class="alert alert-warning">Bu sayfa için <a href="login">giriş</a> gerekli.</div>
}
else
{
    <div class="zk-balance-card">
        <div>
            <div class="zk-balance-label">Bakiyen</div>
            <ZkAmount Amount="balance" Size="xl" />
        </div>
        <div style="max-width:340px;">
            <small style="color:var(--zk-muted);">
                <i class="ti ti-lock"></i> Krediler <b>kapalı devredir</b> — yalnızca hizmet karşılığı
                kazanılır, nakit/TL ile satın alınamaz. Kayıt olunca bir kerelik hoş geldin bakiyesi tanımlanır.
            </small>
        </div>
    </div>

    @if (err is not null) { <div class="alert alert-danger zk-mt">@err</div> }

    <div class="zk-card zk-ledger">
        <h3 style="font-size:18px; margin:0 0 8px;">Hareketler</h3>
        @if (entries.Count == 0)
        {
            <div class="zk-empty">Henüz işlem yok.</div>
        }
        else
        {
            @foreach (var e in entries)
            {
                <div class="zk-ledger-row">
                    <div class="zk-ledger-ic @TypeBadge(e.EntryType)"><i class="ti @TypeIcon(e.EntryType)"></i></div>
                    <div class="zk-ledger-main">
                        <div class="zk-ledger-type">@TypeName(e.EntryType)</div>
                        <div class="zk-ledger-date">@e.CreatedAt.ToLocalTime().ToString("d MMM yyyy, HH:mm", Tr)</div>
                    </div>
                    <div class="@(e.Amount < 0 ? "zk-amount-neg" : "zk-amount-pos")">
                        @(e.Amount < 0 ? "" : "+")@e.Amount.ToString("0.##", Tr) ZK
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private static readonly CultureInfo Tr = CultureInfo.GetCultureInfo("tr-TR");

    private bool ready;
    private string? err;
    private decimal balance;
    private List<LedgerEntryDto> entries = new();

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureLoadedAsync();
        if (Auth.IsAuthenticated) await Load();
        ready = true;
    }

    private async Task Load()
    {
        try
        {
            var w = await Api.GetWalletAsync();
            balance = w!.Balance;
            entries = w.Entries.OrderByDescending(x => x.CreatedAt).ToList();
        }
        catch (ApiException ex) { err = ex.Message; }
    }

    private static string TypeName(LedgerEntryType t) => t switch
    {
        LedgerEntryType.OpeningBalance => "Açılış bakiyesi",
        LedgerEntryType.ServicePayment => "Hizmet ödemesi",
        LedgerEntryType.ServiceEarning => "Hizmet kazancı",
        LedgerEntryType.Commission => "Komisyon",
        _ => t.ToString()
    };

    private static string TypeIcon(LedgerEntryType t) => t switch
    {
        LedgerEntryType.OpeningBalance => "ti-wallet",
        LedgerEntryType.ServicePayment => "ti-arrow-up-right",
        LedgerEntryType.ServiceEarning => "ti-arrow-down-left",
        LedgerEntryType.Commission => "ti-businessplan",
        _ => "ti-coin"
    };

    private static string TypeBadge(LedgerEntryType t) => t switch
    {
        LedgerEntryType.ServiceEarning => "zk-badge-green",
        LedgerEntryType.ServicePayment => "zk-badge-red",
        LedgerEntryType.Commission => "zk-badge-amber",
        _ => "zk-badge-cyan"
    };
}
