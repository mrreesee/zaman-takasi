@page "/register"
@inject ApiClient Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Kayıt — Zaman Takası</PageTitle>

<div class="zk-auth-wrap">
    <div class="zk-auth-card">
        <div class="zk-auth-head">
            <BrandLogo Href="" Size="46" ShowText="false" />
            <h1>Aramıza katıl</h1>
            <p>Birkaç saniyede hesap oluştur, takasa başla.</p>
        </div>

        <div class="zk-field">
            <label>Görünen ad</label>
            <input class="form-control" @bind="displayName" @bind:event="oninput" placeholder="Adın" />
        </div>
        <div class="zk-field">
            <label>E-posta</label>
            <input class="form-control" type="email" @bind="email" @bind:event="oninput" placeholder="ornek@posta.com" />
        </div>
        <div class="zk-field">
            <label>Parola</label>
            <input class="form-control" type="password" @bind="password" @bind:event="oninput" placeholder="••••••••" />
            <small style="display:block; margin-top:6px; color:var(--zk-muted); font-size:12.5px;">
                <i class="ti ti-info-circle"></i> En az <b>6 karakter</b>, içinde en az <b>1 küçük harf</b> ve <b>1 rakam</b> olmalı. (örn. <code>deneme123</code>)
            </small>
        </div>

        <button class="zk-btn zk-btn-primary zk-block" @onclick="Submit" disabled="@busy">
            @if (busy) { <span>Oluşturuluyor…</span> } else { <span><i class="ti ti-user-plus"></i> Kayıt ol</span> }
        </button>

        @if (error is not null) { <div class="alert alert-danger zk-mt">@error</div> }

        <div class="zk-auth-foot">Zaten hesabın var mı? <a href="login">Giriş yap</a></div>
    </div>
</div>

@code {
    private string displayName = "";
    private string email = "";
    private string password = "";
    private string? error;
    private bool busy;

    private async Task Submit()
    {
        error = null; busy = true;
        try
        {
            var resp = await Api.RegisterAsync(new RegisterRequest(email, password, displayName));
            await Auth.SignInAsync(resp!);
            Nav.NavigateTo("/listings");
        }
        catch (ApiException ex) { error = ex.Message; }
        finally { busy = false; }
    }
}
