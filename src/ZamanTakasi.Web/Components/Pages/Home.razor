@page "/"
@using System.Globalization
@inject AuthState Auth
@inject Loc L

<PageTitle>Zaman Takası</PageTitle>

@* ---------- Koyu hero ---------- *@
<section class="zk-fullbleed zk-dark">
    <div class="zk-container">
        <div class="zk-hero">
            <div>
                <span class="zk-pill-tag"><i class="ti ti-sparkles"></i> @L["home.badge"]</span>
                <h1>@L["home.title.pre"] <span class="grad">@L["home.title.accent"]</span> @L["home.title.post"]</h1>
                <p class="zk-hero-lead">@L["home.lead"]</p>
                <div class="zk-hero-btns">
                    <a class="zk-btn zk-btn-primary" href="@(Auth.IsAuthenticated ? "listings" : "register")">
                        <i class="ti ti-rocket"></i> @L["home.cta.start"]
                    </a>
                    <a class="zk-btn zk-btn-ghost-dark" href="#nasil-calisir">
                        <i class="ti ti-player-play"></i> @L["home.cta.how"]
                    </a>
                </div>
                <div class="zk-trust">
                    <div class="zk-stack">
                        <span style="background:#1fb6d4; color:#04222b;">B</span>
                        <span style="background:#6a4fd0; color:#fff;">C</span>
                        <span style="background:#2e9c54; color:#fff;">D</span>
                        <span style="background:#e0a52e; color:#3a2700;">E</span>
                        <span style="background:#13263d; color:#cfe0f2; font-size:11px;">+1k</span>
                    </div>
                    <div class="zk-trust-txt"><b>@L.Fmt("home.trust", 1200)</b> · <span class="stars">★★★★★</span> <b>@Rating</b></div>
                </div>
            </div>

            <div class="zk-hero-art">
                <div class="zk-glass zk-glass-1">
                    <div class="zk-glass-row">
                        <div class="zk-glass-ic" style="background:rgba(31,182,212,0.18); color:var(--zk-cyan-bright);"><i class="ti ti-code"></i></div>
                        <div><b>@L["home.demo.web"]</b><small>Bob · ★ @FmtNum(4.9m)</small></div>
                    </div>
                    <div class="zk-glass-foot">
                        <ZkAmount Amount="2" /> <span class="zk-btn zk-btn-primary zk-btn-sm">@L["home.demo.book"]</span>
                    </div>
                </div>
                <div class="zk-glass zk-glass-2">
                    <div class="zk-glass-row">
                        <div class="zk-glass-ic" style="background:rgba(224,165,46,0.18); color:#e0a52e;"><i class="ti ti-palette"></i></div>
                        <div><b>@L["home.demo.design"]</b><small>Ceren · ★ @FmtNum(5m)</small></div>
                    </div>
                    <div class="zk-glass-foot">
                        <ZkAmount Amount="3" /> <span class="zk-btn zk-btn-primary zk-btn-sm">@L["home.demo.book"]</span>
                    </div>
                </div>
                <div class="zk-glass zk-glass-3">
                    <div class="zk-glass-row">
                        <div class="zk-glass-ic" style="background:rgba(46,156,84,0.18); color:#4cc878;"><i class="ti ti-language"></i></div>
                        <div><b>@L["home.demo.lang"]</b><small>Deniz · ★ @FmtNum(4.7m)</small></div>
                    </div>
                    <div class="zk-glass-foot">
                        <ZkAmount Amount="1" /> <span class="zk-btn zk-btn-primary zk-btn-sm">@L["home.demo.book"]</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ---------- Nasıl çalışır ---------- *@
<section id="nasil-calisir" class="zk-section">
    <div class="zk-section-head">
        <span class="zk-eyebrow"><i class="ti ti-route"></i> @L["home.steps.eyebrow"]</span>
        <h2>@L["home.steps.title"]</h2>
        <p>@L["home.steps.sub"]</p>
    </div>
    <div class="zk-steps">
        <div class="zk-step">
            <div class="zk-step-num">01</div>
            <div class="zk-step-badge"><i class="ti ti-user-plus"></i></div>
            <h3>@L["home.step1.title"]</h3>
            <p>@L["home.step1.body"]</p>
        </div>
        <div class="zk-step">
            <div class="zk-step-num">02</div>
            <div class="zk-step-badge"><i class="ti ti-calendar-check"></i></div>
            <h3>@L["home.step2.title"]</h3>
            <p>@L["home.step2.body"]</p>
        </div>
        <div class="zk-step">
            <div class="zk-step-num">03</div>
            <div class="zk-step-badge"><i class="ti ti-coin"></i></div>
            <h3>@L["home.step3.title"]</h3>
            <p>@L["home.step3.body"]</p>
        </div>
    </div>
</section>

@* ---------- Seviyeler ---------- *@
<section class="zk-section" style="padding-top:0;">
    <div class="zk-section-head">
        <span class="zk-eyebrow"><i class="ti ti-stairs-up"></i> @L["home.tiers.eyebrow"]</span>
        <h2>@L["home.tiers.title"]</h2>
        <p>@L["home.tiers.sub"]</p>
    </div>
    <div class="zk-tiers">
        <div class="zk-tier">
            <div class="zk-tier-name">Basic</div>
            <div class="zk-tier-mult">×1</div>
            <ul>
                <li><i class="ti ti-check"></i> @L["home.tier.basic.f1"]</li>
                <li><i class="ti ti-check"></i> @L["home.tier.basic.f2"]</li>
                <li><i class="ti ti-check"></i> @L["home.tier.basic.f3"]</li>
            </ul>
            <a class="zk-btn zk-btn-ghost" href="register">@L["home.tier.select"]</a>
        </div>
        <div class="zk-tier featured">
            <div class="zk-tier-flag">@L["home.tier.verified.flag"]</div>
            <div class="zk-tier-name">Verified</div>
            <div class="zk-tier-mult">×2</div>
            <ul>
                <li><i class="ti ti-check"></i> @L["home.tier.verified.f1"]</li>
                <li><i class="ti ti-check"></i> @L["home.tier.verified.f2"]</li>
                <li><i class="ti ti-check"></i> @L["home.tier.verified.f3"]</li>
            </ul>
            <a class="zk-btn zk-btn-primary" href="register">@L["home.tier.select"]</a>
        </div>
        <div class="zk-tier">
            <div class="zk-tier-name">Professional</div>
            <div class="zk-tier-mult">×3</div>
            <ul>
                <li><i class="ti ti-check"></i> @L["home.tier.pro.f1"]</li>
                <li><i class="ti ti-check"></i> @L["home.tier.pro.f2"]</li>
                <li><i class="ti ti-check"></i> @L["home.tier.pro.f3"]</li>
            </ul>
            <a class="zk-btn zk-btn-ghost" href="register">@L["home.tier.select"]</a>
        </div>
    </div>
</section>

@code {
    private string Rating => FmtNum(4.9m);

    private static string FmtNum(decimal v) => v.ToString("0.#", CultureInfo.CurrentCulture);

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureLoadedAsync();
    }
}
