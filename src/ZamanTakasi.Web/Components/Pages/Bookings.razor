@page "/bookings"
@using System.Globalization
@inject ApiClient Api
@inject AuthState Auth

<PageTitle>Rezervasyonlarım — Zaman Takası</PageTitle>

<div class="zk-page-head">
    <div>
        <h1>Rezervasyonlarım</h1>
        <p>Sağladığın ve aldığın hizmetleri buradan yönet.</p>
    </div>
</div>

@if (!ready)
{
    <p style="color:var(--zk-muted);">Yükleniyor…</p>
}
else if (!Auth.IsAuthenticated)
{
    <div class="alert alert-warning">Bu sayfa için <a href="login">giriş</a> gerekli.</div>
}
else
{
    @if (err is not null) { <div class="alert alert-danger zk-mt">@err</div> }

    <h3 class="zk-subhead"><i class="ti ti-arrow-down-left"></i> Gelen — hizmeti ben sağlıyorum</h3>
    @RenderList(incoming, asProvider: true)

    <h3 class="zk-subhead"><i class="ti ti-arrow-up-right"></i> Giden — hizmeti ben alıyorum</h3>
    @RenderList(outgoing, asProvider: false)
}

@code {
    private static readonly CultureInfo Tr = CultureInfo.GetCultureInfo("tr-TR");

    private bool ready;
    private string? err;
    private List<BookingDto> incoming = new();
    private List<BookingDto> outgoing = new();

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureLoadedAsync();
        if (Auth.IsAuthenticated) await Load();
        ready = true;
    }

    private async Task Load()
    {
        try
        {
            var all = await Api.MyBookingsAsync() ?? new();
            incoming = all.Where(b => b.ProviderUserId == Auth.UserId).OrderByDescending(b => b.CreatedAt).ToList();
            outgoing = all.Where(b => b.RequesterUserId == Auth.UserId).OrderByDescending(b => b.CreatedAt).ToList();
        }
        catch (ApiException ex) { err = ex.Message; }
    }

    private RenderFragment RenderList(List<BookingDto> items, bool asProvider) => @<text>
        @if (items.Count == 0)
        {
            <div class="zk-empty">Kayıt yok.</div>
        }
        else
        {
            @foreach (var b in items)
            {
                <div class="zk-booking-row">
                    <div class="zk-booking-ic"><i class="ti ti-calendar-event"></i></div>
                    <div class="zk-booking-main">
                        <div class="zk-booking-title">@FormatHours(b.Hours) saatlik hizmet</div>
                        <div class="zk-booking-sub">@b.CreatedAt.ToLocalTime().ToString("d MMM yyyy, HH:mm", Tr)</div>
                    </div>
                    <ZkAmount Amount="b.CreditCost" />
                    <span class="zk-badge @StatusBadge(b.Status)"><i class="ti @StatusIcon(b.Status)"></i> @StatusName(b.Status)</span>
                    <div class="zk-booking-actions">
                        @if (asProvider && b.Status == BookingStatus.Pending)
                        {
                            <button class="zk-btn zk-btn-primary zk-btn-sm" @onclick="() => Do(() => Api.AcceptAsync(b.Id))">Kabul et</button>
                        }
                        @if (asProvider && b.Status == BookingStatus.Accepted)
                        {
                            <button class="zk-btn zk-btn-primary zk-btn-sm" @onclick="() => Do(() => Api.CompleteAsync(b.Id))">Tamamla</button>
                        }
                        @if (b.Status == BookingStatus.Pending || b.Status == BookingStatus.Accepted)
                        {
                            <button class="zk-btn zk-btn-ghost zk-btn-sm" @onclick="() => Do(() => Api.CancelAsync(b.Id))">İptal</button>
                        }
                    </div>
                </div>
            }
        }
    </text>;

    private async Task Do(Func<Task<BookingDto?>> action)
    {
        err = null;
        try { await action(); await Load(); }
        catch (ApiException ex) { err = ex.Message; }
    }

    private static string FormatHours(decimal h) => h.ToString("0.##", Tr);

    private static string StatusName(BookingStatus s) => s switch
    {
        BookingStatus.Pending => "Bekliyor",
        BookingStatus.Accepted => "Kabul edildi",
        BookingStatus.Completed => "Tamamlandı",
        BookingStatus.Cancelled => "İptal edildi",
        _ => s.ToString()
    };

    private static string StatusIcon(BookingStatus s) => s switch
    {
        BookingStatus.Pending => "ti-clock",
        BookingStatus.Accepted => "ti-check",
        BookingStatus.Completed => "ti-circle-check",
        BookingStatus.Cancelled => "ti-x",
        _ => "ti-point"
    };

    private static string StatusBadge(BookingStatus s) => s switch
    {
        BookingStatus.Pending => "zk-badge-amber",
        BookingStatus.Accepted => "zk-badge-cyan",
        BookingStatus.Completed => "zk-badge-green",
        BookingStatus.Cancelled => "zk-badge-red",
        _ => "zk-badge-ink"
    };
}
